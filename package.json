{
  "name": "knote",
  "displayName": "KNote",
  "version": "0.13.11",
  "description": "KNote — a local-first Markdown vault with a checkbox-driven Kanban board, wiki links, and vault-wide search, as a VS Code extension",
  "publisher": "bradleykrone",
  "main": "./dist/extension.js",
  "private": true,
  "author": "Bradley Krone",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BradleyKrone/KNote.git"
  },
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Notebooks",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.knote",
    "onLanguage:markdown"
  ],
  "contributes": {
    "commands": [
      {
        "command": "knote.initializeVault",
        "title": "KNote: Initialize Vault in This Workspace"
      },
      {
        "command": "knote.openBoard",
        "title": "KNote: Open Kanban Board"
      },
      {
        "command": "knote.openBoardForNote",
        "title": "KNote: Open Board for This Note"
      },
      {
        "command": "knote.openBoardForPath",
        "title": "KNote: Open Board for Note Path"
      },
      {
        "command": "knote.openNoteAt",
        "title": "KNote: Open Note at Line"
      },
      {
        "command": "knote.openTimeline",
        "title": "KNote: Open Timeline"
      },
      {
        "command": "knote.openMachineLog",
        "title": "KNote: Open Machine Log"
      },
      {
        "command": "knote.openGraph",
        "title": "KNote: Open Graph View"
      },
      {
        "command": "knote.openSettings",
        "title": "KNote: Open Vault Settings"
      },
      {
        "command": "knote.openWelcome",
        "title": "KNote: Open Welcome & Feature Guide"
      },
      {
        "command": "knote.openLivePreview",
        "title": "KNote: Open in Live Preview",
        "icon": "$(book)"
      },
      {
        "command": "knote.reopenAsText",
        "title": "KNote: Reopen as Raw Text",
        "icon": "$(code)"
      },
      {
        "command": "knote.cleanupAttachments",
        "title": "KNote: Clean Up Orphaned Attachments"
      },
      {
        "command": "knote.openWeeklyNote",
        "title": "KNote: Open This Week's Note"
      },
      {
        "command": "knote.quickCapture",
        "title": "KNote: Quick Capture to Weekly Note"
      },
      {
        "command": "knote.insertTemplate",
        "title": "KNote: Insert Template"
      },
      {
        "command": "knote.cycleTaskStatus",
        "title": "KNote: Cycle Task Status"
      },
      {
        "command": "knote.setTaskStatus",
        "title": "KNote: Set Task Status…"
      },
      {
        "command": "knote.insertCheckbox",
        "title": "KNote: Toggle Checkbox on Line"
      },
      {
        "command": "knote.insertTaskNote",
        "title": "KNote: Add Task Note"
      },
      {
        "command": "knote.insertMilestone",
        "title": "KNote: Insert Milestone"
      },
      {
        "command": "knote.insertMilestoneImportant",
        "title": "KNote: Insert Important Milestone"
      },
      {
        "command": "knote.insertMachineEntry",
        "title": "KNote: Insert Machine Log Entry"
      },
      {
        "command": "knote.format.bold",
        "title": "KNote: Toggle Bold"
      },
      {
        "command": "knote.format.italic",
        "title": "KNote: Toggle Italic"
      },
      {
        "command": "knote.format.strikethrough",
        "title": "KNote: Toggle Strikethrough"
      },
      {
        "command": "knote.format.code",
        "title": "KNote: Toggle Inline Code"
      },
      {
        "command": "knote.searchVault",
        "title": "KNote: Search Vault"
      },
      {
        "command": "knote.renameTag",
        "title": "KNote: Rename Tag Across Vault"
      },
      {
        "command": "knote.deprecateTag",
        "title": "KNote: Deprecate Tag"
      },
      {
        "command": "knote.undeprecateTag",
        "title": "KNote: Restore Deprecated Tag"
      }
    ],
    "customEditors": [
      {
        "viewType": "knote.liveEditor",
        "displayName": "KNote Live Preview",
        "selector": [
          {
            "filenamePattern": "**/*.md"
          }
        ],
        "priority": "default"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "knote",
          "title": "KNote",
          "icon": "resources/knote-icon.svg"
        },
        {
          "id": "knoteWeekly",
          "title": "This Week",
          "icon": "resources/icon-weekly.svg"
        },
        {
          "id": "knoteBoards",
          "title": "KNote Kanban",
          "icon": "resources/icon-kanban.svg"
        },
        {
          "id": "knoteMachines",
          "title": "KNote Machines",
          "icon": "resources/icon-machine.svg"
        },
        {
          "id": "knoteTimeline",
          "title": "KNote Timeline",
          "icon": "resources/icon-timeline.svg"
        }
      ]
    },
    "views": {
      "knote": [
        {
          "id": "knote.search",
          "name": "Search",
          "type": "webview"
        },
        {
          "id": "knote.backlinks",
          "name": "Backlinks",
          "type": "webview"
        },
        {
          "id": "knote.tags",
          "name": "Tags"
        },
        {
          "id": "knote.properties",
          "name": "Properties",
          "type": "webview",
          "visibility": "collapsed"
        }
      ],
      "knoteWeekly": [
        {
          "id": "knote.weekly",
          "name": "Weekly Notes"
        }
      ],
      "knoteBoards": [
        {
          "id": "knote.boards",
          "name": "Boards"
        }
      ],
      "knoteMachines": [
        {
          "id": "knote.machines",
          "name": "Machines"
        }
      ],
      "knoteTimeline": [
        {
          "id": "knote.milestones",
          "name": "Milestones"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "knote.reopenAsText",
          "when": "activeCustomEditorId == knote.liveEditor",
          "group": "navigation@1"
        },
        {
          "command": "knote.openLivePreview",
          "when": "editorLangId == markdown && !activeCustomEditorId",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "knote.renameTag",
          "when": "view == knote.tags && viewItem == tag"
        },
        {
          "command": "knote.deprecateTag",
          "when": "view == knote.tags && viewItem == tag"
        },
        {
          "command": "knote.undeprecateTag",
          "when": "view == knote.tags && viewItem == deprecatedTag"
        }
      ],
      "commandPalette": [
        {
          "command": "knote.deprecateTag",
          "when": "false"
        },
        {
          "command": "knote.undeprecateTag",
          "when": "false"
        },
        {
          "command": "knote.openBoardForPath",
          "when": "false"
        },
        {
          "command": "knote.openNoteAt",
          "when": "false"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "knote.weekly",
        "contents": "No KNote vault is open in this workspace.\n[Initialize Vault](command:knote.initializeVault)"
      },
      {
        "view": "knote.boards",
        "contents": "No KNote vault is open in this workspace.\n[Initialize Vault](command:knote.initializeVault)"
      },
      {
        "view": "knote.machines",
        "contents": "No KNote vault is open in this workspace.\n[Initialize Vault](command:knote.initializeVault)"
      },
      {
        "view": "knote.milestones",
        "contents": "No KNote vault is open in this workspace.\n[Initialize Vault](command:knote.initializeVault)"
      }
    ],
    "keybindings": [
      {
        "command": "knote.cycleTaskStatus",
        "key": "ctrl+l",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "knote.setTaskStatus",
        "key": "ctrl+alt+l",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "knote.insertCheckbox",
        "key": "ctrl+alt+x",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "knote.insertTaskNote",
        "key": "ctrl+alt+enter",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "knote.openBoard",
        "key": "ctrl+alt+k"
      },
      {
        "command": "knote.openWeeklyNote",
        "key": "ctrl+alt+w"
      },
      {
        "command": "knote.quickCapture",
        "key": "ctrl+alt+j"
      },
      {
        "command": "knote.format.bold",
        "key": "ctrl+b",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "knote.format.italic",
        "key": "ctrl+i",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "knote.format.strikethrough",
        "key": "ctrl+shift+x",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "knote.format.code",
        "key": "ctrl+alt+c",
        "when": "editorTextFocus && editorLangId == markdown"
      }
    ],
    "walkthroughs": [
      {
        "id": "knote.gettingStarted",
        "title": "Get started with KNote",
        "description": "A vault of plain Markdown notes with a Kanban board, wiki links, and a timeline built in.",
        "steps": [
          {
            "id": "knote.step.vault",
            "title": "Open or create a vault",
            "description": "Open your notes folder, or initialize a fresh one.\n[Initialize Vault](command:knote.initializeVault)",
            "media": {
              "markdown": "resources/walkthrough/vault.md"
            }
          },
          {
            "id": "knote.step.board",
            "title": "Open the Kanban board",
            "description": "Every checkbox in your vault, as a draggable card.\n[Open Board](command:knote.openBoard)",
            "media": {
              "markdown": "resources/walkthrough/board.md"
            }
          },
          {
            "id": "knote.step.links",
            "title": "Link your notes",
            "description": "[[Wiki links]], backlinks, and the graph.",
            "media": {
              "markdown": "resources/walkthrough/links.md"
            }
          },
          {
            "id": "knote.step.weekly",
            "title": "Weekly notes & quick capture",
            "description": "One hotkey to this week's note, one to capture a thought.\n[Open This Week's Note](command:knote.openWeeklyNote)",
            "media": {
              "markdown": "resources/walkthrough/weekly.md"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "KNote",
      "properties": {
        "knote.decorations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show KNote decorations in notes: tag pills, priority markers, milestone lines, and dimmed task-meta lines."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webviews.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile-tests": "tsc -p test/tsconfig.json",
    "test:integration": "npm run build && npm run compile-tests && vscode-test",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "package": "vsce package"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@dnd-kit/core": "^6.3.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.7.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/unist": "^3.0.3",
    "@types/vscode": "^1.97.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.2.0",
    "chokidar": "^4.0.0",
    "dayjs": "^1.11.21",
    "esbuild": "^0.25.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "lucide-react": "^0.469.0",
    "minisearch": "^7.2.0",
    "mocha": "^11.7.6",
    "p-limit": "^6.2.0",
    "prettier": "^3.9.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.63.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vitest": "^2.1.0",
    "yaml": "^2.9.0",
    "zustand": "^5.0.0"
  },
  "dependencies": {
    "typo-js": "^1.3.2"
  }
}
